{
  "name": "desloppify",
  "version": "1.0.1",
  "description": "Your AI wrote spaghetti. This eats it. The definitive AI slop detector for any codebase.",
  "type": "module",
  "packageManager": "bun@1.3.10",
  "bin": {
    "desloppify": "bin/desloppify.js"
  },
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./src/public-api.ts",
      "default": "./src/public-api.ts"
    },
    "./plugin-api": {
      "types": "./plugin-api.d.ts",
      "import": "./plugin-api.js",
      "require": "./plugin-api.cjs",
      "default": "./plugin-api.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "bin/",
    "src/",
    ".githooks/",
    "skills/",
    "plugin-api.js",
    "plugin-api.cjs",
    "plugin-api.d.ts",
    "index.d.ts",
    "README.md",
    "LICENSE",
    "!bin/**/*.test.*",
    "!src/**/*.test.*"
  ],
  "scripts": {
    "start": "bun src/cli.ts",
    "scan": "bun src/cli.ts scan",
    "score": "bun src/cli.ts score",
    "fix": "bun src/cli.ts fix",
    "rules": "bun src/cli.ts rules",
    "check-tools": "bun src/cli.ts check-tools",
    "test": "bun test",
    "setup-hooks": "git config core.hooksPath .githooks && chmod +x .githooks/pre-commit .githooks/pre-push",
    "build": "bun build --compile --minify --bytecode --outfile desloppify src/cli.ts",
    "release:sync-version": "node scripts/sync-version.mjs",
    "release:check": "npm pack --dry-run"
  },
  "keywords": [
    "ai-slop",
    "code-quality",
    "linter",
    "cleanup",
    "dead-code",
    "cli",
    "agent",
    "desloppify"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FasalZein/desloppify.git"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@clack/prompts": "1.2.0",
    "citty": "0.2.2"
  }
}
