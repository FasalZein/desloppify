{
  "name": "desloppify",
  "version": "2.0.0",
  "description": "Agent-agnostic code cleanup CLI. Detects 116+ rules across 16 categories of AI code rot.",
  "type": "module",
  "bin": {
    "desloppify": "./bin/desloppify.js"
  },
  "files": [
    "bin/",
    "src/",
    "skills/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "bun src/cli.ts",
    "scan": "bun src/cli.ts scan",
    "score": "bun src/cli.ts score",
    "fix": "bun src/cli.ts fix",
    "rules": "bun src/cli.ts rules",
    "check-tools": "bun src/cli.ts check-tools",
    "build": "bun build --compile --minify --bytecode --outfile desloppify src/cli.ts"
  },
  "keywords": [
    "ai-slop",
    "code-quality",
    "linter",
    "cleanup",
    "dead-code",
    "cli",
    "agent"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/FasalZein/desloppify"
  },
  "license": "MIT",
  "engines": {
    "bun": ">=1.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "citty": "0.2.2"
  }
}
