{
  "name": "desloppify",
  "version": "1.0.1",
  "description": "Your AI wrote spaghetti. This eats it. The definitive AI slop detector for any codebase.",
  "type": "module",
  "bin": {
    "desloppify": "bin/desloppify.js"
  },
  "exports": {
    "./plugin-api": "./src/plugin-api.ts",
    "./src/*": "./src/*",
    "./package.json": "./package.json"
  },
  "files": [
    "bin/",
    "src/",
    "skills/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "bun src/cli.ts",
    "scan": "bun src/cli.ts scan",
    "score": "bun src/cli.ts score",
    "fix": "bun src/cli.ts fix",
    "rules": "bun src/cli.ts rules",
    "check-tools": "bun src/cli.ts check-tools",
    "test": "bun test",
    "setup-hooks": "git config core.hooksPath .githooks && chmod +x .githooks/pre-commit .githooks/pre-push",
    "build": "bun build --compile --minify --bytecode --outfile desloppify src/cli.ts"
  },
  "keywords": [
    "ai-slop",
    "code-quality",
    "linter",
    "cleanup",
    "dead-code",
    "cli",
    "agent",
    "desloppify"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FasalZein/desloppify.git"
  },
  "license": "MIT",
  "engines": {
    "bun": ">=1.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@clack/prompts": "1.2.0",
    "citty": "0.2.2"
  }
}
